---
const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title.replace('墨香阁', '冬去春来')}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <!-- 不蒜子统计 -->
  <script async src="//busuanzi.ibruce.info/busuanzi/2.3/busuanzi.pure.min.js"></script>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@400;700&family=ZCOOL+KuaiLe&display=swap" rel="stylesheet">

  <style is:global>
    :root {
      --primary: #1a1a2e;
      --secondary: #16213e;
      --accent: #e94560;
      --gold: #d4af37;
      --text: #eee;
      --text-muted: #888;
      --card-bg: rgba(255,255,255,0.05);
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: 'Noto Serif SC', serif;
      background: linear-gradient(135deg, #0f0f1a 0%, #1a1a2e 50%, #0d0d15 100%);
      min-height: 100vh;
      color: var(--text);
      line-height: 1.8;
    }

    a { color: var(--gold); text-decoration: none; transition: 0.3s; }
    a:hover { color: #fff; }

    .container { max-width: 1000px; margin: 0 auto; padding: 0 20px; }

    header {
      padding: 30px 0;
      border-bottom: 1px solid rgba(212,175,55,0.2);
      margin-bottom: 40px;
    }

    .logo {
      font-family: 'ZCOOL KuaiLe', cursive;
      font-size: 2rem;
      background: linear-gradient(90deg, var(--gold), #f4d67a, var(--gold));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      letter-spacing: 4px;
    }

    nav { float: right; margin-top: -40px; }
    nav a { margin-left: 25px; font-size: 0.95rem; }

    .categories {
      display: flex;
      gap: 20px;
      justify-content: center;
      margin: 50px 0;
    }

    .cat-btn {
      padding: 15px 40px;
      background: var(--card-bg);
      border: 1px solid rgba(212,175,55,0.3);
      border-radius: 8px;
      cursor: pointer;
      transition: all 0.3s;
      font-size: 1.1rem;
    }

    .cat-btn:hover, .cat-btn.active {
      background: rgba(212,175,55,0.15);
      border-color: var(--gold);
      transform: translateY(-3px);
    }

    .article-list {
      display: grid;
      gap: 30px;
    }

    .article-card {
      background: var(--card-bg);
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 16px;
      padding: 30px;
      transition: 0.3s;
    }

    .article-card:hover {
      border-color: var(--gold);
      transform: translateX(10px);
    }

    .article-title { font-size: 1.4rem; margin-bottom: 10px; }
    .article-desc { color: var(--text-muted); font-size: 0.95rem; }
    .article-meta { margin-top: 15px; font-size: 0.85rem; color: var(--text-muted); }

    .tip-section {
      text-align: center;
      padding: 40px;
      background: var(--card-bg);
      border-radius: 16px;
      margin-top: 40px;
    }

    .tip-title { font-size: 1.3rem; margin-bottom: 20px; color: var(--gold); }

    .tip-images {
      display: flex;
      justify-content: center;
      gap: 40px;
      flex-wrap: wrap;
    }

    .tip-img {
      width: 150px;
      border-radius: 12px;
      cursor: pointer;
      transition: 0.3s;
    }

    .tip-img:hover { transform: scale(1.1); }

    .comment-section {
      margin-top: 50px;
      padding: 30px;
      background: var(--card-bg);
      border-radius: 16px;
    }

    .comment-title { margin-bottom: 20px; color: var(--gold); }

    footer {
      text-align: center;
      padding: 40px 0;
      margin-top: 60px;
      border-top: 1px solid rgba(255,255,255,0.1);
      color: var(--text-muted);
      font-size: 0.9rem;
    }

    .views { margin: 0 10px; }
  </style>
</head>

<body>
  <div class="container">
    <header>
      <div class="logo">📚 冬去春来</div>
      <nav>
        <a href="/">首页</a>
        <a href="#about">关于</a>
      </nav>
    </header>

    <slot />

    <footer>
      <p>
        访问量 <span id="busuanzi_value_site_pv" class="views">--</span> |
        访客 <span id="busuanzi_value_site_uv" class="views">--</span>
      </p>
      <p style="margin-top:10px">© 2026 冬去春来 · 用心记录每一天</p>
    </footer>
  </div>
</body>
</html>